IOBUF PORT "sdram_a[10]"  IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[0]"  IO_TYPE=LVCMOS33;
IOBUF PORT "sdram_dq[1]"  IO_TYPE=LVCMOS33;
