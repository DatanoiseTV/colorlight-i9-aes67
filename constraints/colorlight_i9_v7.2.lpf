## ---- I2S / TDM (routed through SODIMM GPIO header) ----
## All five pins are confirmed valid LFE5U-45F-6BG381C balls and appear in
## the i9 v7.2 SODIMM GPIO map (Colorlight-FPGA-Projects):
##    SODIMM 67 = T17  (mclk)
##    SODIMM 61 = R17  (bclk)
##    SODIMM 63 = P17  (lrck)
##    SODIMM 75 = N17  (dout)
##    SODIMM 65 = M17  (din)
##
## NOTE: SODIMM pin 41 (= L2) is shared with the on-board LED D2 - do NOT
## use it for audio. The full GPIO pool exposed on SODIMM 41-156 includes:
##   L2 R1 T1 U1 Y2 K18 C18 W1 V1 M1 T18 N2 R18 N3 R17 T2 P17 M3 M17 T3
##   T17 R3 U18 N4 U17 M4 P18 L4 N17 L5 N18 P16 M18 J16 L20 J18 L18 J17
##   K20 H18 K19 H17 J20 G18 J19 H16 H20 F18 G20 G16 G19 E18 F20 F17 F19
##   F16 E20 E16 E19 E17 D20 D18 D19 D17 C20 G5 B20 D16 B19 F5 B18 E6
##   A19 E5 C17 F4 A18 E4 D3 F1 C4 F3 B4 G3 C3 H3 E3 H4 A3 H5 C2 J4 B1 J5
##   C1 K3 D2 K4 D1 K5 E2 B3 E1 A2 F2 B2
LOCATE COMP "i2s_mclk" SITE "T17";
LOCATE COMP "i2s_bclk" SITE "R17";
LOCATE COMP "i2s_lrck" SITE "P17";
LOCATE COMP "i2s_dout" SITE "N17";
LOCATE COMP "i2s_din"  SITE "M17";

IOBUF PORT "i2s_mclk" IO_TYPE=LVCMOS33;
IOBUF PORT "i2s_bclk" IO_TYPE=LVCMOS33;
IOBUF PORT "i2s_lrck" IO_TYPE=LVCMOS33;
IOBUF PORT "i2s_dout" IO_TYPE=LVCMOS33;
IOBUF PORT "i2s_din"  IO_TYPE=LVCMOS33;

## ---- SPI Flash (W25Q64JVSIQ, directly on PCB) ----
## Used by FPGA for configuration; accessible after boot for firmware storage
LOCATE COMP "flash_cs"   SITE "R2";
LOCATE COMP "flash_miso" SITE "V2";
LOCATE COMP "flash_mosi" SITE "W2";
LOCATE COMP "flash_sck"  SITE "U3";

IOBUF PORT "flash_cs"   IO_TYPE=LVCMOS33;
IOBUF PORT "flash_miso" IO_TYPE=LVCMOS33;
IOBUF PORT "flash_mosi" IO_TYPE=LVCMOS33;
IOBUF PORT "flash_sck"  IO_TYPE=LVCMOS33;
